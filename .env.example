# Supabase (CRM principal)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — server-only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase de Reparto (proyecto secundario, integración server-side)
NEXT_PUBLIC_REPARTO_SUPABASE_URL=https://YOUR-REPARTO-PROJECT.supabase.co
NEXT_PUBLIC_REPARTO_SUPABASE_ANON_KEY=eyJ...
# Solo server-side. Las API routes /api/reparto/* lo usan para saltarse la RLS.
REPARTO_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Base44 — TERAVINO Flow (consignaciones / tomas de inventario)
# Solo server-side. Las rutas /api/consignaciones/* lo usan para llamar al REST de Base44.
BASE44_APP_ID=69fb9aa2d0a67510e8c4f123
BASE44_API_KEY=

# Base44 — Teravino Docs (formatos / acuerdos con clientes)
# Solo server-side. Las rutas /api/documentos/* lo usan para leer plantillas y
# guardar documentos generados. BASE44_DOCS_URL es la URL publicada del app en
# Base44 (con o sin /api). Si la API key es de cuenta, puede reutilizar BASE44_API_KEY.
BASE44_DOCS_APP_ID=6a247798d4e7409d06fd67e2
BASE44_DOCS_URL=https://teravino-docs.base44.app
BASE44_DOCS_API_KEY=
# Nota: hoy la REST de este app no exige auth (lectura/escritura públicas con la
# URL). Por eso basta con setear BASE44_DOCS_URL; BASE44_DOCS_API_KEY puede
# quedar vacío y cae a BASE44_API_KEY. Conviene poner auth al app en Base44.

# Base44 — Teravino Flota (parque vehicular / flotilla)
# Solo server-side. Las rutas /api/flota/* y las pantallas /flota lo usan para
# leer y actualizar vehículos. BASE44_FLOTA_URL es la URL publicada del app en
# Base44 (con o sin /api). Si la API key es de cuenta, puede caer a BASE44_API_KEY.
BASE44_FLOTA_APP_ID=6a2091d32a6360cbea06f7c2
BASE44_FLOTA_URL=https://teravino-flota.base44.app
BASE44_FLOTA_API_KEY=
# Nota: hoy la REST de este app no exige auth (lectura/escritura públicas con la
# URL), igual que Teravino Docs. Por eso basta con setear BASE44_FLOTA_URL;
# BASE44_FLOTA_API_KEY puede quedar vacío y cae a BASE44_API_KEY.

# Cobranza — envío de recordatorios de pago (Resend)
# Solo server-side. El dominio teravino.com debe estar verificado en Resend.
RESEND_API_KEY=
COBRANZA_FROM_EMAIL="TERAVINO Cobranza <cobranza@teravino.com>"
# Cobranza inteligente — envío REAL de correos por Resend desde "Redactar
# cobranza". Por seguridad viene apagado: con el flag en false (default) el
# botón "Enviar" SOLO registra el contacto en la bitácora y abre mailto/wa.me
# con el texto prellenado (no manda nada solo). Ponlo en "true" para que el
# correo se envíe por Resend tras la confirmación explícita de la persona.
COBRANZA_ENVIO_REAL="false"
# Remitente para el envío de muestras por correo (mismo dominio verificado).
VENTAS_FROM_EMAIL="TERAVINO <ventas@teravino.com>"
# Destinatario por defecto del correo de muestras (área de surtido/envío).
PEDIDOS_EMAIL="pedidos@teravino.com"

# Conciliación bancaria — lectura de PDF y sugerencias asistidas (Claude)
# Solo server-side. Las rutas /api/cartera/conciliacion/* la usan para leer
# estados de cuenta en PDF y proponer conciliaciones. NUNCA exponer al cliente.
ANTHROPIC_API_KEY=
# Opcional: modelo a usar (default claude-sonnet-4-6).
ANTHROPIC_MODEL="claude-sonnet-4-6"

# App
NEXT_PUBLIC_APP_NAME="TERAVINO CRM"
